  - groupName: SpillCleanup
    isEnabled: 1
    steps:
    - stepName: BreakGlass
      narrationClip: {fileID: 8300000, guid: 5dce47b2569ab3547b150a428b9f60ef, type: 3}
      instruction: Great work! Now let's simulate an accident so we can learn how
        to deal with it. Pick up a test tube and drop it on the floor. This, of course,
        should not be done in a real lab.
      actionComplete: 0
      actionType: 0
      targetObject: {fileID: 0}
      customActionEvent:
        m_PersistentCalls:
          m_Calls: []
      postActions: []
    - stepName: BrokenGlass
      narrationClip: {fileID: 8300000, guid: 7d036e385f1da6f43aed3e55355c56fa, type: 3}
      instruction: Oh no ! You've broken glass. Let's handle how to dispose of it
        safely.
